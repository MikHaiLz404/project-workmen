{
  "name": "workmen-workspace",
  "version": "0.1.0",
  "private": true,
  "description": "Workmen game asset workbench -- monorepo root (Rust + JS frontend for Tauri 2).",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "tsc": "tsc -p apps/desktop/tsconfig.json --noEmit",
    "tsc:build": "tsc -p apps/desktop/tsconfig.json",
    "frontend:build": "npm run tsc:build",
    "test": "cargo test --workspace",
    "fmt": "cargo fmt --all -- --check"
  },
  "engines": {
    "node": ">=20"
  }
}
